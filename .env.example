# LithuanianBD Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ============================================================
# SUPABASE
# ============================================================
# Get these from: https://supabase.com → Your Project → Settings → API

# Your project's public anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to browser, server-only
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# APP CONFIG (optional overrides)
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LithuanianBD
